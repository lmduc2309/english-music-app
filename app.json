{
  "expo": {
    "name": "SingLish",
    "slug": "english-music-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "singlish",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": { "image": "./assets/splash-icon.png", "resizeMode": "contain", "backgroundColor": "#0F0F1A" },
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.singlish.app", "infoPlist": { "NSMicrophoneUsageDescription": "SingLish needs microphone access to record your singing for pronunciation scoring." } },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#0F0F1A" }, "package": "com.singlish.app", "permissions": ["RECORD_AUDIO"] },
    "web": { "bundler": "metro", "favicon": "./assets/favicon.png" },
    "plugins": ["expo-router", "expo-secure-store", ["expo-av", { "microphonePermission": "SingLish needs microphone access to record your singing." }]]
  }
}
